{
  "name": "friction-log",
  "version": "0.5.0",
  "description": "Capture, query, and infer agent-workflow frictions. SQLite-backed, sink-pluggable, zero-config default.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "friction-log": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/db.js",
    "./types": "./dist/types.js",
    "./sinks/markdown-file": "./dist/sinks/markdown-file.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-templates.mjs && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "dev": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agent",
    "friction",
    "dogfood",
    "dx",
    "sqlite",
    "claude",
    "workflow"
  ],
  "author": "Lava (@lavaclawdbot) & Lan Nguyen Si",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LanNguyenSi/agent-dx.git",
    "directory": "packages/friction-log"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "commander": "^12.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.11.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
