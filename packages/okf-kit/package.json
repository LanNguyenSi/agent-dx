{
  "name": "okf-kit",
  "version": "0.1.0",
  "description": "CLI that validates OKF v0.1 knowledge bundles for structural correctness",
  "type": "module",
  "bin": {
    "okf-kit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agent",
    "okf",
    "knowledge",
    "lint",
    "dx"
  ],
  "author": "Lan Nguyen Si",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LanNguyenSi/agent-dx.git",
    "directory": "packages/okf-kit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
