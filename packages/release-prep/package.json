{
  "name": "release-prep",
  "version": "0.1.0",
  "description": "CLI tool to automate release preparation with changelog generation and version management",
  "type": "module",
  "bin": {
    "release-prep": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "release",
    "changelog",
    "semver",
    "git",
    "github",
    "automation",
    "version"
  ],
  "author": "Lava",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "ora": "^8.1.1",
    "semver": "^7.6.3",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/semver": "^7.5.8",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
