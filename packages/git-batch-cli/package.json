{
  "name": "git-batch-cli",
  "version": "0.1.0",
  "description": "Batch CLI for syncing multiple git repositories in a shared workspace",
  "type": "commonjs",
  "bin": {
    "git-batch": "./bin/git-batch.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:ci": "vitest run && env npm_config_cache=.npm-cache npm pack --dry-run"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "vitest": "^4.1.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LanNguyenSi/agent-dx.git",
    "directory": "packages/git-batch-cli"
  },
  "bugs": {
    "url": "https://github.com/LanNguyenSi/agent-dx/issues"
  },
  "homepage": "https://github.com/LanNguyenSi/agent-dx/tree/master/packages/git-batch-cli#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git",
    "cli",
    "batch",
    "workspace",
    "automation",
    "developer-tools"
  ],
  "license": "MIT"
}
