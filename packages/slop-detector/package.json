{
  "name": "slop-detector",
  "version": "0.1.0",
  "description": "Configurable AI-slop linter for PRs — catches the visible tells of AI-generated code, prose, and UIs",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "slop-detector": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./packs/agent-tics": "./dist/packs/agent-tics.js",
    "./packs/prose-slop": "./dist/packs/prose-slop.js",
    "./packs/comment-slop": "./dist/packs/comment-slop.js",
    "./packs/code-slop": "./dist/packs/code-slop.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agent",
    "lint",
    "slop",
    "pr-review",
    "dx",
    "claude",
    "playbook"
  ],
  "author": "Lava (@lavaclawdbot) & Lan Nguyen Si",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LanNguyenSi/agent-dx.git",
    "directory": "packages/slop-detector"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.59.1",
    "@typescript-eslint/types": "^8.59.1",
    "commander": "^12.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
